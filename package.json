		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router-dom": "7.13.1",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@ecom-mfe/eslint-config": "^0.0.0",
		"@ecom-mfe/rspack-config": "^1.0.2",
		"@ecom-mfe/typescript-config": "^0.0.0",
		"@rspack/cli": "1.3.11",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"autoprefixer": "^10.4.21",
