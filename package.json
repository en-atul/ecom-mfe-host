		"identity-obj-proxy": "^3.0.0",
		"jest": "^29.7.0",
		"picocolors": "^1.1.1",
		"postcss": "^8.5.3",
		"postcss-loader": "^8.1.1",
		"sass": "^1.87.0",
		"sass-loader": "^16.0.5",
		"style-loader": "^4.0.0",
		"ts-jest": "^29.2.5",
