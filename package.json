{
	"name": "host-app",
	"version": "1.0.0",
	"license": "MIT",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "NODE_ENV=production rspack --config rspack.config.js --mode=production",
		"clean-build": "gulp",
		"lint": "eslint \"src/**/*.{ts,tsx}\"",
		"test": "jest -c \"$PWD/jest.config.cjs\"",
		"test:watch": "jest -c \"$PWD/jest.config.cjs\" --watch",
		"dev": "NODE_ENV=development rspack serve --config rspack.config.js --mode=development",
		"serve": "rspack serve --config rspack.config.js --mode=production"
	},
	"dependencies": {
		"@ecom-mfe/ecommerce-core": "^1.0.0",
		"@ecom-mfe/styles": "^1.0.0",
