{
	"installCommand": "pnpm install --frozen-lockfile",
	"buildCommand": "pnpm build",
	"outputDirectory": "dist",
	"routes": [
		{
			"src": "/assets/(.*)",
			"headers": {
				"Cache-Control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/index.html"
		}
	],
	"git": {
		"deploymentEnabled": true
	}
}